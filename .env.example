# ============================================================
# DIGITAL FOOTPRINT GUARDIAN — Environment Variables Template
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Groq — https://console.groq.com/keys  (free tier available)
VITE_GROQ_API_KEY=<your-groq-api-key>

# Leak-Lookup — https://leak-lookup.com/api  (free & paid plans)
VITE_LEAK_LOOKUP_API_KEY=<your-leak-lookup-api-key>

# Optional: HIBP (HaveIBeenPwned) — used in /api/breach.js Vercel function
# HIBP_API_KEY=<your-hibp-api-key>
