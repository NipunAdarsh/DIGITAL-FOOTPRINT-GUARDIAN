# ============================================================
# DIGITAL FOOTPRINT GUARDIAN — .gitignore
# ============================================================

# ── Environment & Secrets ─────────────────────────────────────
# NEVER commit real API keys or credentials
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.*.local

# ── Build Output ──────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak

# ── Vite ──────────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS-generated Files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs & Editors ────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Internal Agent & Design Tools ────────────────────────────
.agents/
.stitch/
.claude/
skills-lock.json

# ── Temporary / Scratch Files ─────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.cache
.cache/

# ── PRD / Internal Docs (optional — remove if you want to share) ──
# PRD.md
# designdoc.md

# ── Supabase (local dev only) ─────────────────────────────────
.supabase/
supabase/.temp/
